{
  "name": "antdv-next-admin",
  "type": "module",
  "version": "1.0.0",
  "description": "A modern Vue 3 admin scaffold based on antdv-next",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "analyze": "vite-bundle-visualizer"
  },
  "dependencies": {
    "@ant-design/colors": "^8.0.1",
    "@antdv-next/icons": "^1.0.0",
    "@iconify-json/ion": "^1.2.6",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/ri": "^1.2.10",
    "@iconify/vue": "^5.0.0",
    "@milkdown/core": "^7.18.0",
    "@milkdown/ctx": "^7.18.0",
    "@milkdown/plugin-block": "^7.18.0",
    "@milkdown/plugin-clipboard": "^7.18.0",
    "@milkdown/plugin-history": "^7.18.0",
    "@milkdown/plugin-listener": "^7.18.0",
    "@milkdown/plugin-prism": "^7.18.0",
    "@milkdown/plugin-slash": "^7.18.0",
    "@milkdown/plugin-tooltip": "^7.18.0",
    "@milkdown/plugin-upload": "^7.18.0",
    "@milkdown/preset-commonmark": "^7.18.0",
    "@milkdown/preset-gfm": "^7.18.0",
    "@milkdown/theme-nord": "^7.18.0",
    "@milkdown/transformer": "^7.18.0",
    "@milkdown/vue": "^7.18.0",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@tiptap/vue-3": "^3.19.0",
    "antdv-next": "^1.0.0",
    "axios": "^1.6.5",
    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "lodash-es": "^4.17.21",
    "pinia": "^2.1.7",
    "pinyin-pro": "^3.28.0",
    "vue": "^3.4.0",
    "vue-echarts": "^6.6.8",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.2.5",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@faker-js/faker": "^8.3.1",
    "@playwright/test": "^1.58.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/ui": "4.0.18",
    "@vue/test-utils": "^2.4.6",
    "commander": "^14.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "handlebars": "^4.7.8",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "sass": "^1.69.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-mock-dev-server": "^1.4.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  }
}
